{
  "name": "@xochi-fi/pxe-bridge",
  "version": "0.1.0",
  "type": "module",
  "description": "JSON-RPC bridge from EVM intent solvers to Aztec shielded settlement via embedded PXE",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xochi-fi/pxe-bridge"
  },
  "main": "dist/index.js",
  "types": "dist/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aztec/accounts": "4.1.3",
    "@aztec/aztec.js": "4.1.3",
    "@aztec/noir-contracts.js": "4.1.3",
    "@aztec/wallets": "4.1.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
